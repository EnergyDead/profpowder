---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import PriceCard from '@/components/ui/PriceCard.astro';
import { pricing } from '@/data/site';
---

<section id="pricing" class="py-12 sm:py-16">
  <Container class="space-y-8">
    <SectionTitle
      eyebrow="Прайс"
      title="Тарифы под объём и задачу"
      subtitle="Стоимость зависит от подготовки, геометрии изделия и объёма партии."
    />

    <div class="grid gap-4 lg:grid-cols-3">
      {pricing.map((plan) => (
        <PriceCard planName={plan.planName} price={plan.price} period={plan.period} />
      ))}
    </div>
  </Container>
</section>
