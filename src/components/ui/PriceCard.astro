---
interface Props {
  planName?: string;
  price?: string;
  class?: string;
}

const { planName = 'План', price = '0 ₽', class: className = '' } = Astro.props as Props;
---

<article
  class={`relative flex min-h-[256px] w-full max-w-[400px] flex-col overflow-hidden rounded-2xl border border-[rgba(231,235,243,0.2)] bg-[#111319] px-6 pb-6 pt-7 shadow-[0_10px_26px_rgba(0,0,0,0.35)] ${className}`}
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_30%_18%,rgba(255,255,255,0.09),transparent_45%),radial-gradient(circle_at_70%_85%,rgba(240,138,36,0.14),transparent_50%)]"
  ></div>

  <div class="relative z-10 flex h-full flex-col items-center text-center">
    <h3 class="text-[36px] font-semibold leading-tight text-[#e4e8ef]">{planName}</h3>

    <p class="mt-4 flex items-end justify-center gap-2 leading-none text-[#e4e8ef]">
      <span class="text-[30px] font-light">от</span>
      <span class="text-[clamp(2rem,2.2vw,2.5rem)] font-semibold">{price}</span>
    </p>

    <button
      type="button"
      class="mt-auto flex h-14 w-full items-center justify-center rounded-[5px] bg-[radial-gradient(circle_at_50%_18%,#f2861f_0%,#eb8121_45%,#e57c22_68%,#893f16_100%)] text-lg font-semibold text-[#f8f1e8] shadow-[0_4px_4px_rgba(0,0,0,0.25)] transition hover:brightness-105"
    >
      Оставить заявку
    </button>
  </div>
</article>
