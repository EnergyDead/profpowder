---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import TabButton from '@/components/ui/TabButton.astro';
import { portfolio } from '@/data/site';
---

<section id="portfolio" class="py-12 sm:py-16">
  <Container class="space-y-8">
    <SectionTitle
      eyebrow={portfolio.section.eyebrow}
      title={portfolio.section.title}
      subtitle={portfolio.section.subtitle}
    />

    <div class="flex flex-wrap gap-2">
      {portfolio.tabs.map((tab, index) => (
        <TabButton label={tab} isActive={index === 0} />
      ))}
    </div>

    <div class="ui-surface grid gap-4 p-4 sm:grid-cols-2 sm:p-6">
      <div class="overflow-hidden rounded-[var(--radius-ui)] border border-[var(--color-border)]">
        <div class="bg-[var(--color-surface-alt)] px-3 py-2 text-xs uppercase tracking-[0.14em] text-[var(--color-muted)]">{portfolio.beforeLabel}</div>
        <div class="flex h-56 items-center justify-center bg-[var(--color-surface)] text-sm text-[var(--color-muted)] sm:h-72">{portfolio.beforePlaceholder}</div>
      </div>
      <div class="overflow-hidden rounded-[var(--radius-ui)] border border-[var(--color-border)]">
        <div class="bg-[var(--color-surface-alt)] px-3 py-2 text-xs uppercase tracking-[0.14em] text-[var(--color-muted)]">{portfolio.afterLabel}</div>
        <div class="flex h-56 items-center justify-center bg-[var(--color-surface)] text-sm text-[var(--color-muted)] sm:h-72">{portfolio.afterPlaceholder}</div>
      </div>
    </div>
  </Container>
</section>
