---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Advantages from '@/components/sections/Advantages.astro';
import Services from '@/components/sections/Services.astro';
import Pricing from '@/components/sections/Pricing.astro';
import Portfolio from '@/components/sections/Portfolio.astro';
import Partners from '@/components/sections/Partners.astro';
import Contacts from '@/components/sections/Contacts.astro';
import LeadForm from '@/components/sections/LeadForm.astro';
import Footer from '@/components/sections/Footer.astro';
---

<BaseLayout>
  <main>
    <section class="relative overflow-hidden bg-[#060709]">
      <div
        class="pointer-events-none absolute inset-0 bg-cover bg-center bg-no-repeat"
        style="background-image:url('/images/bg-1.png');"
        aria-hidden="true"
      ></div>
      <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(5,7,9,0.95)_0%,rgba(5,7,9,0.86)_48%,rgba(5,7,9,0.72)_100%)]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_24%,rgba(242,134,31,0.17),transparent_44%)]" aria-hidden="true"></div>

      <div class="relative z-10">
        <Hero />
        <Advantages />
      </div>
    </section>
    <Services />
    <Pricing />
    <Portfolio />
    <Partners />
    <Contacts />
    <LeadForm />
  </main>
  <Footer />
</BaseLayout>
