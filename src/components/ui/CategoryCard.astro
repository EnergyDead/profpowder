---
interface Props {
  title?: string;
  countLabel?: string;
  class?: string;
}

const {
  title = 'Category',
  countLabel = '00 items',
  class: className = ''
} = Astro.props as Props;
---

<article class={`ui-surface flex items-center justify-between gap-4 p-4 transition duration-200 hover:border-[var(--color-border-strong)] hover:bg-white/[0.03] ${className}`}>
  <h3 class="text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text)]">{title}</h3>
  <span class="rounded-full border border-[var(--color-border)] px-2.5 py-1 text-xs text-[var(--color-muted)]">{countLabel}</span>
</article>
