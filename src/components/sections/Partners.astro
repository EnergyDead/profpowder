---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import TabButton from '@/components/ui/TabButton.astro';
import { partners } from '@/data/site';
---

<section id="partners" class="py-12 sm:py-16">
  <Container class="space-y-8">
    <SectionTitle
      eyebrow={partners.section.eyebrow}
      title={partners.section.title}
      subtitle={partners.section.subtitle}
    />

    <div class="flex flex-wrap gap-2">
      {partners.tabs.map((tab, index) => (
        <TabButton label={tab} isActive={index === 0} />
      ))}
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {partners.cards.map((partner) => (
        <article class="ui-surface flex min-h-24 items-center justify-center p-6 text-sm uppercase tracking-[0.12em] text-[var(--color-muted)]">
          {partner}
        </article>
      ))}
    </div>
  </Container>
</section>
