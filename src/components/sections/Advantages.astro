---
import Container from '@/components/ui/Container.astro';
import { advantages } from '@/data/site';
---

<section
  id="advantages"
  class="bg-[#060709] bg-cover bg-center bg-no-repeat pt-8 pb-16 lg:pt-10 lg:pb-20"
  style="background-image:url('/images/bg-2.png');"
>
  <Container class="max-w-[1238px] px-6">
    <div class="mx-auto flex w-full max-w-[1238px] flex-col items-center">
      <h2 class="text-center text-[36px] leading-8 font-semibold text-[#E7EBF3]">{advantages.section.title}</h2>

      <div class="mt-10 grid w-full max-w-[980px] grid-cols-1 place-items-center gap-6 sm:grid-cols-2 xl:grid-cols-4 xl:gap-8">
        {advantages.cards.map((item) => (
          <article class="flex h-[192px] w-[208px] flex-col items-center rounded-[14px] border border-[rgba(231,235,243,0.14)] bg-[rgba(10,12,16,0.66)] px-4 pt-6 pb-4 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.02)] backdrop-blur-[2px]">
            <span class="text-[72px] leading-[56px] font-light text-[#E7EBF3]">{item.value}</span>

            <div
              class="mt-3 flex h-12 w-[166px] items-center justify-center rounded-[10px] px-2 text-[14px] leading-4 font-semibold text-white whitespace-pre-line"
              style="background:radial-gradient(129.81% 147.43% at 14.02% 12.5%,#F2861F 0%,#EB8121 36%,#E57C22 65%,#893F16 100%);"
            >
              {item.title}
            </div>

            <p class="mt-3 text-[12px] leading-3 font-normal text-[#E7EBF3] whitespace-pre-line">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </Container>
</section>
