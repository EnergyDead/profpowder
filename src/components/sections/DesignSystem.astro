---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import PrimaryButton from '@/components/ui/PrimaryButton.astro';
import SecondaryButton from '@/components/ui/SecondaryButton.astro';
import FeatureCard from '@/components/ui/FeatureCard.astro';
import CategoryCard from '@/components/ui/CategoryCard.astro';
import PriceCard from '@/components/ui/PriceCard.astro';
import TabButton from '@/components/ui/TabButton.astro';
import InputField from '@/components/ui/InputField.astro';
import TextAreaField from '@/components/ui/TextAreaField.astro';
---

<section class="py-16 sm:py-24">
  <Container class="space-y-10">
    <SectionTitle eyebrow="UI System" title="Dark premium component set" subtitle="Reusable base elements with unified spacing, borders and interaction states" />

    <div class="ui-surface flex flex-wrap gap-3 p-5">
      <PrimaryButton />
      <SecondaryButton />
      <TabButton label="Active tab" isActive={true} />
      <TabButton label="Default tab" />
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <FeatureCard />
      <FeatureCard title="Feature title" description="Another placeholder line" />
      <FeatureCard title="Feature title" description="Another placeholder line" />
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <CategoryCard />
      <CategoryCard title="Category" countLabel="00 items" />
    </div>

    <div class="grid gap-4 lg:grid-cols-3">
      <PriceCard />
      <PriceCard planName="Plan" price="$0" period="/period" />
      <PriceCard planName="Plan" price="$0" period="/period" />
    </div>

    <form class="ui-surface grid gap-4 p-5 md:grid-cols-2" action="#">
      <InputField id="name-field" label="Input" placeholder="Placeholder" />
      <InputField id="email-field" label="Input" placeholder="Placeholder" type="email" />
      <TextAreaField id="message-field" label="Textarea" placeholder="Placeholder" class="md:col-span-2" />
      <div class="md:col-span-2">
        <PrimaryButton label="Submit" />
      </div>
    </form>
  </Container>
</section>
