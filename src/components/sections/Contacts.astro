---
import Container from '@/components/ui/Container.astro';
---

<section
  id="contacts"
  class="bg-cover bg-center bg-no-repeat py-12 sm:py-16"
  style="background-image:url('/images/bg-5.png');"
>
  <Container class="max-w-[1239px]">
    <h2 class="text-center text-[36px] font-semibold leading-tight text-gray-200">Контакты</h2>

    <div class="mt-8 grid min-h-[320px] overflow-hidden rounded-2xl border border-[rgba(255,255,255,0.16)] bg-[rgba(17,19,25,0.55)] lg:grid-cols-[1fr_1.45fr]">
      <article class="flex h-full flex-col justify-center gap-5 border-b border-[rgba(255,255,255,0.12)] px-8 py-8 lg:border-b-0 lg:border-r lg:border-[rgba(255,255,255,0.12)] lg:px-10">
        <h3 class="text-[36px] font-semibold leading-tight text-[var(--color-text)]">Профи Порошок</h3>

        <p class="text-2xl font-normal text-[var(--color-muted)]">г. Йошкар-Ола, ул, Кирова, 6</p>

        <a href="tel:+79021243369" class="inline-flex items-center gap-3 text-2xl font-normal text-[var(--color-muted)]">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v2a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 3.18 2 2 0 0 1 4.11 1h2a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.5 8.5a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z" />
          </svg>
          <span>+7 (902) 124-33-69</span>
        </a>

        <a href="mailto:porochok12gmail.com" class="inline-flex items-center gap-3 text-2xl font-normal text-[var(--color-muted)] underline decoration-1 underline-offset-4">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path stroke-linecap="round" stroke-linejoin="round" d="m3 7 9 6 9-6" />
          </svg>
          <span>porochok12gmail.com</span>
        </a>

        <a href="https://t.me/DLPowder" target="_blank" rel="noreferrer" class="inline-flex items-center gap-3 text-2xl font-normal text-[var(--color-muted)]">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 3 10 14" />
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 3-7 18-4-7-7-4 18-7Z" />
          </svg>
          <span>@DLPowder</span>
        </a>
      </article>

      <div class="flex h-full items-center justify-center px-6 py-10 text-center">
        <p class="text-[44px] font-semibold leading-none text-gray-200 sm:text-[56px] lg:text-[72px]">КАРТА 2 гис</p>
      </div>
    </div>
  </Container>
</section>
