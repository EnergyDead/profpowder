---
interface Props {
  label?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const {
  label = 'Primary action',
  type = 'button',
  class: className = ''
} = Astro.props as Props;
---

<button
  type={type}
  class={`ui-button ui-focus border-[var(--color-accent)] bg-[var(--color-accent)] text-[#17120c] shadow-[var(--shadow-glow)] hover:bg-[var(--color-accent-strong)] hover:border-[var(--color-accent-strong)] active:translate-y-px active:shadow-none ${className}`}
>
  {label}
</button>
