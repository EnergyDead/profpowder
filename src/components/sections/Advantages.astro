---
import Container from '@/components/ui/Container.astro';
import { advantages } from '@/data/site';
---

<section
  id="advantages"
  class="bg-[#060709] bg-cover bg-center bg-no-repeat pt-6 pb-16 lg:pt-8 lg:pb-20"
  style="background-image:url('/images/bg-2.png');"
>
  <Container class="max-w-[1238px] px-6">
    <div class="mx-auto flex w-full max-w-[1238px] flex-col items-center">
      <h2 class="text-center text-[36px] leading-8 font-semibold text-[#E7EBF3]">{advantages.section.title}</h2>

      <div class="mt-10 grid w-full max-w-[980px] grid-cols-1 place-items-center gap-6 sm:grid-cols-2 xl:grid-cols-4 xl:gap-8">
        {advantages.cards.map((item) => (
          <article class="relative h-48 w-52">
            <div class="absolute inset-0 rounded border border-black"></div>
            <div class="absolute top-[40px] left-1/2 w-full -translate-x-1/2 text-center text-[72px] leading-4 font-light text-[#E8E8E8]">
              {item.value}
            </div>
            <div
              class="absolute top-[74.81px] left-0 h-12 w-52"
              style="background:radial-gradient(ellipse 70.36% 68.52% at 36.11% 34%,#F2861F 0%,#EB8121 19%,#E57C22 39%,#893F16 100%);"
            ></div>
            <div class="absolute top-[87px] left-1/2 w-full -translate-x-1/2 text-center text-sm leading-4 font-semibold text-white whitespace-pre-line">
              {item.title}
            </div>
            <p class="absolute top-[133px] left-1/2 w-full -translate-x-1/2 text-center text-xs leading-3 font-normal text-[#E8E8E8] whitespace-pre-line">
              {item.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </Container>
</section>
