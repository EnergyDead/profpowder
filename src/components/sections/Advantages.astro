---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import FeatureCard from '@/components/ui/FeatureCard.astro';
import { advantages } from '@/data/site';
---

<section id="advantages" class="py-12 sm:py-16">
  <Container class="space-y-8">
    <SectionTitle
      eyebrow="Преимущества"
      title="Почему выбирают ПрофПорошок"
      subtitle="Работаем с понятными сроками, контролем качества на каждом этапе и прозрачным прайсом."
    />

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {advantages.map((item) => (
        <FeatureCard title={`${item.value} — ${item.title}`} description={item.description} />
      ))}
    </div>
  </Container>
</section>
