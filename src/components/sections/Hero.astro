---
import Container from '@/components/ui/Container.astro';
import { hero } from '@/data/site';
---

<section id="hero" class="relative min-h-[92svh] overflow-hidden bg-[#060709]">
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image:url(${hero.image.src})`} aria-hidden="true"></div>
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,7,9,0.95)_0%,rgba(5,7,9,0.86)_48%,rgba(5,7,9,0.72)_100%)]" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_32%,rgba(242,134,31,0.2),transparent_42%)]" aria-hidden="true"></div>

  <Container class="relative z-10 flex min-h-[92svh] max-w-[1238px] flex-col px-6 pt-8 pb-16 lg:pt-10">
    <header class="flex items-center justify-between">
      <a href="#hero" class="inline-flex items-center gap-4 text-[#E7EBF3]">
        <span class="relative block h-[58px] w-[58px] rounded-[8px] border border-white/30 bg-[linear-gradient(155deg,#3c4149_0%,#191d23_100%)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.25)]">
          <span class="absolute left-[13px] top-[10px] h-[38px] w-[9px] rounded-[3px] bg-[linear-gradient(180deg,#d8dde6_0%,#808894_100%)]"></span>
          <span class="absolute left-[13px] top-[10px] h-[9px] w-[32px] rounded-[3px] bg-[linear-gradient(180deg,#d8dde6_0%,#808894_100%)]"></span>
          <span class="absolute left-[36px] top-[10px] h-[38px] w-[9px] rounded-[3px] bg-[linear-gradient(180deg,#d8dde6_0%,#808894_100%)]"></span>
        </span>
        <span class="text-[20px] leading-[20px] font-bold tracking-[0.01em]">{hero.logoText}</span>
      </a>

      <div class="flex items-center gap-9">
        <nav class="hidden items-center gap-7 lg:flex">
          {hero.navItems.map((item) => (
            <a href={item.href} class="text-[16px] leading-6 font-semibold text-[#E7EBF3] transition hover:text-white">
              {item.label}
            </a>
          ))}
        </nav>
        <button
          type="button"
          class="hidden h-[41px] min-w-[162px] rounded-[6px] border border-white/45 px-5 text-[16px] leading-6 font-semibold text-[#E7EBF3] transition hover:border-white hover:text-white lg:inline-flex lg:items-center lg:justify-center"
        >
          {hero.callButtonLabel}
        </button>
      </div>
    </header>

    <div class="mt-[110px] max-w-[690px]">
      <h1 class="whitespace-pre-line text-[64px] leading-[69.81px] font-semibold text-[#E7EBF3]">{hero.title}</h1>

      <p class="mt-9 max-w-[690px] whitespace-pre-line text-[32px] leading-[36px] font-normal text-[#E7EBF3]">
        {hero.subtitleStart}<span class="font-semibold">{hero.subtitleStrong}</span>{hero.subtitleEnd}
      </p>

      <ul class="mt-8 flex h-6 w-[532px] items-center gap-4 text-[14px] leading-6 font-normal text-[#E7EBF3]">
        <li class="flex items-center gap-2">
          <span class="relative inline-flex h-[16px] w-[16px] items-center justify-center rounded-[3px] border border-[#F2861F]/90">
            <span class="absolute top-[2px] h-[2px] w-[8px] rounded-full bg-[#F2861F]"></span>
            <span class="h-[7px] w-[8px] rounded-[2px] border border-[#F2861F]/85"></span>
          </span>
          <span>{hero.benefits[0]}</span>
        </li>
        <li class="h-[6px] w-[6px] rounded-full bg-[radial-gradient(circle,#F2861F_0%,#893F16_100%)]"></li>
        <li>{hero.benefits[1]}</li>
        <li class="h-[6px] w-[6px] rounded-full bg-[radial-gradient(circle,#F2861F_0%,#893F16_100%)]"></li>
        <li>{hero.benefits[2]}</li>
      </ul>

      <button
        type="button"
        class="mt-10 inline-flex h-14 items-center justify-center rounded-[5px] px-7 text-[18px] leading-6 font-semibold text-[#E7EBF3] shadow-[0_4px_4px_rgba(0,0,0,0.25)] transition hover:brightness-105"
        style="background:radial-gradient(129.81% 147.43% at 14.02% 12.5%,#F2861F 0%,#EB8121 36%,#E57C22 65%,#893F16 100%);"
      >
        {hero.ctaLabel}
      </button>
    </div>
  </Container>
</section>
