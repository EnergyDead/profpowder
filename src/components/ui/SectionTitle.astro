---
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  class?: string;
}

const {
  eyebrow = 'Section',
  title = 'Section title',
  subtitle = 'Optional short supporting text',
  class: className = ''
} = Astro.props as Props;
---

<header class={`space-y-3 ${className}`}>
  <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-muted)]">{eyebrow}</p>
  <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] sm:text-3xl">{title}</h2>
  <p class="max-w-2xl text-sm text-[var(--color-muted)] sm:text-base">{subtitle}</p>
</header>
