---
interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = 'Feature title',
  description = 'Short feature description placeholder',
  class: className = ''
} = Astro.props as Props;
---

<article class={`ui-surface space-y-3 p-5 transition duration-200 hover:border-[var(--color-border-strong)] ${className}`}>
  <div class="h-1 w-10 rounded-full bg-[var(--color-accent)]/70 shadow-[var(--shadow-glow)]"></div>
  <h3 class="text-base font-semibold text-[var(--color-text)]">{title}</h3>
  <p class="text-sm text-[var(--color-muted)]">{description}</p>
</article>
