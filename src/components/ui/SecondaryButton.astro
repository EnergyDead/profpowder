---
interface Props {
  label?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const {
  label = 'Secondary action',
  type = 'button',
  class: className = ''
} = Astro.props as Props;
---

<button
  type={type}
  class={`ui-button ui-focus border-[var(--color-border)] bg-transparent text-[var(--color-text)] hover:border-[var(--color-border-strong)] hover:bg-white/5 active:translate-y-px ${className}`}
>
  {label}
</button>
