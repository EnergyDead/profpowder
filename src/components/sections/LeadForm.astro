---
import Container from '@/components/ui/Container.astro';

const leadBenefits = [
  'Бесплатно\nуточним стоимость',
  'Работаем\nчетко по срокам',
  'Оплата по факту\nготовности',
  'Даем полную\nгарантию'
];
---

<section id="lead-form" class="py-12 sm:py-16">
  <Container class="max-w-[1238px] space-y-8 px-6">
    <div class="mx-auto w-full max-w-[1238px]">
      <h2 class="text-center text-[36px] leading-[1.1] font-semibold text-[#E7EBF3]">Закажите порошковую покраску</h2>
      <p class="mx-auto mt-4 max-w-[720px] text-center text-[16px] leading-6 font-normal text-[#E7EBF3]">
        Отправьте фото изделия - узнаете точную цену и сроки покраски
      </p>

      <ul class="mx-auto mt-10 grid w-full max-w-[980px] grid-cols-1 place-items-center gap-6 sm:grid-cols-2 xl:grid-cols-4 xl:gap-8">
        {leadBenefits.map((benefit, index) => (
          <li class="flex h-[136px] w-[208px] flex-col items-center rounded-[14px] border border-[rgba(231,235,243,0.14)] bg-[rgba(10,12,16,0.66)] px-4 pt-3 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.02)] backdrop-blur-[2px]">
            <span class="text-[72px] leading-[56px] font-light text-[#E7EBF3]">{index + 1}</span>

            <span
              class="mt-3 flex h-12 w-[166px] items-center justify-center rounded-[10px] px-2 text-center text-[14px] leading-4 font-semibold text-white whitespace-pre-line"
              style="background:radial-gradient(129.81% 147.43% at 14.02% 12.5%,#F2861F 0%,#EB8121 36%,#E57C22 65%,#893F16 100%);"
            >
              {benefit}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <div class="flex justify-center">
      <form
        class="w-full max-w-[595.77px] rounded-[5px] border border-[rgba(50,56,68,0.85)] bg-[rgba(9,12,18,0.82)] px-10 py-9 shadow-[inset_0_1px_0_rgba(255,255,255,0.03)] backdrop-blur-sm min-h-[676px]"
        action="#"
        method="post"
      >
        <div class="space-y-5">
          <label for="lead-name" class="block space-y-2">
            <span class="block text-[16px] leading-6 font-medium text-[#D6DCE8]">Ваше имя*</span>
            <input
              id="lead-name"
              name="name"
              type="text"
              class="h-12 w-full rounded-[5px] border border-[rgba(58,63,75,0.95)] bg-[rgba(11,15,22,0.76)] px-4 text-[16px] text-[#E7EBF3] outline-none transition focus:border-[rgba(242,134,31,0.85)]"
              placeholder="Введите ваше имя"
            />
          </label>

          <label for="lead-phone" class="block space-y-2">
            <span class="block text-[16px] leading-6 font-medium text-[#D6DCE8]">Телефон*</span>
            <input
              id="lead-phone"
              name="phone"
              type="tel"
              class="h-12 w-full rounded-[5px] border border-[rgba(58,63,75,0.95)] bg-[rgba(11,15,22,0.76)] px-4 text-[16px] text-[#E7EBF3] outline-none transition focus:border-[rgba(242,134,31,0.85)]"
              placeholder="+7 (___) ___-__-__"
            />
          </label>

          <label for="lead-comment" class="block space-y-2">
            <span class="block text-[16px] leading-6 font-medium text-[#D6DCE8]">Комментарии</span>
            <textarea
              id="lead-comment"
              name="comment"
              class="h-[112px] w-full resize-none rounded-[5px] border border-[rgba(58,63,75,0.95)] bg-[rgba(11,15,22,0.76)] px-4 py-3 text-[16px] text-[#E7EBF3] outline-none transition focus:border-[rgba(242,134,31,0.85)]"
              placeholder="Введите комментарий"
            ></textarea>
          </label>

          <div class="space-y-2">
            <span class="block text-[16px] leading-6 font-medium text-[#D6DCE8]">Прикрепить фото</span>
            <label
              for="lead-file"
              class="relative flex h-12 w-full max-w-[288px] cursor-pointer items-center justify-between overflow-hidden rounded-[5px] border border-[rgba(58,63,75,0.95)] bg-[rgba(11,15,22,0.76)] px-4 text-[#E7EBF3]"
            >
              <span
                class="pointer-events-none absolute inset-0 opacity-45"
                style="background:radial-gradient(140% 100% at 0% 0%, rgba(242, 134, 31, 0.28) 0%, rgba(242, 134, 31, 0) 70%);"
              ></span>
              <span class="relative z-10 text-[24px] leading-none font-medium">+</span>
              <span class="relative z-10 text-[16px] leading-6 font-medium">Прикрепить фото</span>
            </label>
            <input id="lead-file" name="photo" type="file" class="sr-only" />
          </div>
        </div>

        <button
          type="submit"
          class="mt-9 flex h-20 w-full max-w-[482px] items-center justify-center rounded-[5px] text-center text-[36px] leading-none font-semibold text-[#F7FAFF] shadow-[0_4px_4px_rgba(0,0,0,0.25)]"
          style="background:radial-gradient(129.81% 147.43% at 14.02% 12.5%, #F2861F 0%, #EB8121 36%, #E57C22 65%, #893F16 100%);"
        >
          Заказать расчет
        </button>
      </form>
    </div>
  </Container>
</section>
