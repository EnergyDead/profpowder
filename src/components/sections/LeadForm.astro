---
import Container from '@/components/ui/Container.astro';
import InputField from '@/components/ui/InputField.astro';
import TextAreaField from '@/components/ui/TextAreaField.astro';
import PrimaryButton from '@/components/ui/PrimaryButton.astro';
import { formLabels } from '@/data/site';

const leadBenefits = [
  'Бесплатно\nуточним стоимость',
  'Работаем\nчетко по срокам',
  'Оплата по факту\nготовности',
  'Даем полную\nгарантию'
];
---

<section id="lead-form" class="py-12 sm:py-16">
  <Container class="max-w-[1238px] space-y-8 px-6">
    <div class="mx-auto w-full max-w-[1238px]">
      <h2 class="text-center text-[36px] leading-[1.1] font-semibold text-[#E7EBF3]">Закажите порошковую покраску</h2>
      <p class="mx-auto mt-4 max-w-[720px] text-center text-[16px] leading-6 font-normal text-[#E7EBF3]">
        Отправьте фото изделия - узнаете точную цену и сроки покраски
      </p>

      <ul class="mx-auto mt-10 grid w-full max-w-[980px] grid-cols-1 place-items-center gap-6 sm:grid-cols-2 xl:grid-cols-4 xl:gap-8">
        {leadBenefits.map((benefit, index) => (
          <li class="flex h-[136px] w-[208px] flex-col items-center rounded-[14px] border border-[rgba(231,235,243,0.14)] bg-[rgba(10,12,16,0.66)] px-4 pt-3 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.02)] backdrop-blur-[2px]">
            <span class="text-[72px] leading-[56px] font-light text-[#E7EBF3]">{index + 1}</span>

            <span
              class="mt-3 flex h-12 w-[166px] items-center justify-center rounded-[10px] px-2 text-center text-[14px] leading-4 font-semibold text-white whitespace-pre-line"
              style="background:radial-gradient(129.81% 147.43% at 14.02% 12.5%,#F2861F 0%,#EB8121 36%,#E57C22 65%,#893F16 100%);"
            >
              {benefit}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <form class="ui-surface grid gap-4 p-5 sm:p-6 md:grid-cols-2" action="#" method="post">
      <InputField id="lead-name" label={formLabels.fields.name.label} placeholder={formLabels.fields.name.placeholder} />
      <InputField id="lead-phone" label={formLabels.fields.phone.label} placeholder={formLabels.fields.phone.placeholder} type="tel" />
      <TextAreaField
        id="lead-comment"
        label={formLabels.fields.comment.label}
        placeholder={formLabels.fields.comment.placeholder}
        class="md:col-span-2"
      />

      <label for="lead-file" class="block space-y-2 md:col-span-2">
        <span class="text-xs uppercase tracking-[0.12em] text-[var(--color-muted)]">{formLabels.fields.file.label}</span>
        <input
          id="lead-file"
          type="file"
          class="ui-control ui-focus file:mr-3 file:rounded-md file:border-0 file:bg-[var(--color-accent)] file:px-3 file:py-2 file:text-sm file:font-medium file:text-[#17120c]"
        />
      </label>

      <div class="md:col-span-2">
        <PrimaryButton label={formLabels.submitButton} type="submit" class="w-full sm:w-auto" />
      </div>
    </form>
  </Container>
</section>
